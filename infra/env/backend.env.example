# ──────────────────────────────────────────────────────────────────────────────
# RAG Research Assistant — Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# ⚠️ NEVER commit the real `.env` file to version control.

# ── App ──
ENV=production
LOG_LEVEL=info
PORT=8080

# ── Database (Neon Serverless Postgres + pgvector) ──
# Get this from neon.tech (must include sslmode=require)
DATABASE_URL=postgresql://user:password@ep-cool-butterfly-123456.us-east-2.aws.neon.tech/rag_assistant?sslmode=require

# ── Redis (Upstash Serverless) ──
# Get this from upstash.com
REDIS_URL=https://upstash-url.upstash.io
REDIS_TOKEN=your_upstash_token

# ── Ollama (Local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Gemini (Google AI) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Auth0 (Authentication) ──
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://api.rag-assistant.com

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","https://your-frontend-domain.com"]
